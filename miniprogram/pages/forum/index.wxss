/** 论坛页面样式 */

/* 搜索栏行 */
.forum-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx 16rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 通知铃铛图标 */
.forum-nav__icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

/* 论坛头部 */
.forum-header__logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1a56db, #0284c7);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 积分横幅 */
.forum-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
}
.forum-banner__left {
  display: flex;
  align-items: center;
}

/* 筛选标签 */
.forum-tabs {
  overflow-x: auto;
  white-space: nowrap;
}
.forum-tabs__item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
  flex-shrink: 0;
  position: relative;
}
.forum-tabs__active {
  position: relative;
}
.forum-tabs__indicator {
  width: 40rpx;
  height: 6rpx;
  background: #1a56db;
  border-radius: 3rpx;
  margin-top: 4rpx;
}

/* 帖子卡片 */
.forum-post {
  overflow: visible;
  width: 100%;
  box-sizing: border-box;
}

/* 视频缩略图 */
.forum-post__video {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.forum-post__play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}
.forum-post__duration {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(0,0,0,0.65);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 多图 */
.forum-post__images {
  display: flex;
  gap: 8rpx;
}
.forum-post__img {
  width: calc((100% - 16rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: 12rpx;
  background: #e2e2e2;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 积分按钮 */
.forum-post__points {
  border: 1rpx solid #1a56db;
  background: rgba(26,86,219,0.05);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* FAB */
.forum-fab {
  position: fixed;
  bottom: 140rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a56db, #3b82f6);
  box-shadow: 0 8rpx 24rpx rgba(26,86,219,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}
.forum-fab:active {
  transform: scale(0.92);
  opacity: 0.85;
}
