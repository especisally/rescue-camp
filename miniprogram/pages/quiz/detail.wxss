/* 刷题中心 - 题库详细页样式 */
page {
  background-color: #f9f9f9;
}

.page {
  padding-bottom: 200rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background-color: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #1a1c1c;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1c1c;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 16rpx;
}

.nav-placeholder {
  width: 60rpx;
  height: 60rpx;
}

/* 进度条 */
.progress-wrap {
  margin-top: 88rpx;
  padding: 24rpx 24rpx 8rpx;
  background-color: #fff;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #f1f1f1;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #1a56db;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 题目卡片 */
.question-card {
  margin: 20rpx 24rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.question-number {
  font-size: 26rpx;
  color: #5f3f3b;
  font-weight: bold;
}

.question-type {
  font-size: 22rpx;
  color: #1a56db;
  background-color: rgba(26, 86, 219, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.question-text {
  font-size: 32rpx;
  color: #1a1c1c;
  line-height: 1.6;
  font-weight: 500;
}

/* 选项列表 */
.options-list {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  position: relative;
}

.option-item:active {
  background-color: #fafafa;
}

.option-selected {
  border-color: #005BAC;
  background-color: rgba(0, 91, 172, 0.04);
}

.option-correct {
  border-color: #4CAF50;
  background-color: rgba(76, 175, 80, 0.06);
}

.option-wrong {
  border-color: #1a56db;
  background-color: rgba(26, 86, 219, 0.04);
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #f1f1f1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #5f3f3b;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-correct .option-label {
  background-color: #4CAF50;
  color: #fff;
}

.option-wrong .option-label {
  background-color: #1a56db;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a1c1c;
  line-height: 1.5;
}

.option-mark {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4CAF50;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.mark-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.wrong-mark {
  background-color: #1a56db;
}

.mark-cross {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 解析卡片 */
.explanation-card {
  margin: 0 24rpx 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  border-left: 6rpx solid #005BAC;
  box-sizing: border-box;
}

.explanation-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.explanation-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1c1c;
}

.explanation-text {
  font-size: 26rpx;
  color: #5f3f3b;
  line-height: 1.7;
}

/* 操作按钮行 */
.action-row {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 99;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-prev {
  border: 2rpx solid #d0d0d0;
  background-color: #fff;
}

.action-btn-text {
  font-size: 28rpx;
  color: #5f3f3b;
}

.action-next {
  background-color: #1a56db;
}

.action-submit {
  background-color: #FF9800;
}

.action-next-text {
  color: #fff;
  font-weight: bold;
}

.action-fav {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f1f1f1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-fav-active {
  background-color: rgba(26, 86, 219, 0.1);
}

.action-fav-icon {
  font-size: 40rpx;
  color: #1a56db;
}

/* 答题卡按钮 */
.sheet-btn-wrap {
  padding: 24rpx;
  display: flex;
  justify-content: center;
}

.sheet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1a56db;
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
}

.sheet-btn-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.sheet-btn-text {
  font-size: 26rpx;
  color: #1a56db;
  font-weight: bold;
}

/* 答题卡弹层 */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet-panel {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx 48rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1c1c;
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}

.sheet-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}

.sheet-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background-color: #f1f1f1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5f3f3b;
}

.sheet-done {
  background-color: #1a56db;
  color: #fff;
}

.sheet-current {
  border: 3rpx solid #005BAC;
  box-sizing: border-box;
}

.sheet-close {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background-color: #f1f1f1;
  border-radius: 12rpx;
}

.sheet-close-text {
  font-size: 30rpx;
  color: #5f3f3b;
}
