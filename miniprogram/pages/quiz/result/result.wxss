.result-page{min-height:100vh;background:#f9f9f9}
.result-nav{background:#fff;border-bottom:1rpx solid #f0f0f0}
.result-nav__inner{display:flex;align-items:center;justify-content:space-between;height:88rpx;padding:0 24rpx}
.result-nav__back{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;background:#f1f1f1}
.result-nav__back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}
.result-nav__title{color:#1a1c1c;flex:1;text-align:center}
.result-nav__placeholder{width:64rpx}
.result-scroll{height:calc(100vh - 88rpx - 120rpx)}
.score-section{padding:40rpx 24rpx;background:#fff;margin:16rpx 24rpx;border-radius:16rpx;display:flex;flex-direction:column;align-items:center}
.score-circle__outer{width:200rpx;height:200rpx;border-radius:50%;border:12rpx solid #1a56db;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(26,86,219,0.05)}
.score-number{font-size:64rpx;font-weight:bold;color:#1a56db;line-height:1}
.score-percent{font-size:28rpx;color:#1a56db}
.score-label{margin-top:12rpx}
.stats-row{padding:0 24rpx;width:100%;box-sizing:border-box}
.stat-card{background:#f9f9f9;border-radius:12rpx;padding:20rpx}
.stat-card__num{font-size:40rpx;font-weight:bold}
.stat-card__label{margin-top:4rpx}
.comment-section{padding:24rpx;display:flex;flex-direction:column;align-items:center}
.review-section{padding:24rpx;background:#fff;margin:0 24rpx;border-radius:16rpx}
.review-item{padding:16rpx 0;border-bottom:1rpx solid #f5f5f5}
.review-item:last-child{border-bottom:none}
.review-item__num{color:#999;flex-shrink:0}
.review-item__title{color:#1a1c1c}
.result-actions{position:fixed;bottom:0;left:0;right:0;display:flex;gap:16rpx;padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));background:#fff;border-top:1rpx solid #f0f0f0;z-index:50}
