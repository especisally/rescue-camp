/* 刷题中心 - 主页样式 */
page {
  background-color: #f9f9f9;
}

.page {
  padding-bottom: 40rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background-color: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #1a1c1c;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a56db;
}

.nav-search {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-search-icon {
  font-size: 34rpx;
}

/* Hero 区域 */
.hero-section {
  margin-top: 88rpx;
  height: 300rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1a56db 0%, #1e40af 50%, #0f1a4a 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 32rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.hero-search-bar {
  width: 100%;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
}

.hero-search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.hero-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1c1c;
}

.hero-search-placeholder {
  color: #bbb;
}

/* 筛选标签 */
.filter-tabs {
  background-color: #fff;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  display: flex;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5f3f3b;
  background-color: #f1f1f1;
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-tab-active {
  background-color: #1a56db;
  color: #fff;
  font-weight: bold;
}

/* 题库列表 */
.bank-list {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.bank-card {
  background-color: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
  padding: 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.bank-badge {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 0 12rpx 0 12rpx;
  font-weight: bold;
}

.bank-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 40rpx;
}

.bank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bank-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1c1c;
  line-height: 1.4;
}

.bank-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.bank-action {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.bank-action-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 统计卡片 */
.stats-row {
  padding: 16rpx 24rpx;
  display: flex;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-card {
  flex: 1;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.stat-blue {
  background-color: #005BAC;
}

.stat-gray {
  background-color: #607D8B;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 12rpx;
}
