page {
  background-color: #f9f9f9;
}

.page {
  min-height: 100vh;
}

.custom-nav {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a56db;
}

.content {
  padding: 24rpx;
}

/* 占位区 */
.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.placeholder-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1c1c;
  margin-bottom: 16rpx;
}

.placeholder-desc {
  font-size: 26rpx;
  color: #5f3f3b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.placeholder-btn {
  background: linear-gradient(135deg, #1a56db, #3b82f6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

/* 预览区 */
.preview-section {
  margin-top: 32rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1c1c;
  margin-bottom: 20rpx;
}

.preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.preview-card-icon {
  font-size: 48rpx;
}

.preview-card-name {
  font-size: 24rpx;
  color: #1a1c1c;
  font-weight: 500;
}
