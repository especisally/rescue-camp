/* pages/training/index.wxss */
.page {
  min-height: 100vh;
  background: #f9f9f9;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.custom-nav {
  background: #1a56db;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 36rpx;
  color: #fff;
}

.nav-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 搜索栏 */
.search-wrap {
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f1f1f1;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1a1c1c;
}

/* 筛选 */
.filter-bar {
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5f3f3b;
  background: #f1f1f1;
}

.filter-item.active {
  color: #fff;
  background: #1a56db;
}

/* 内容 */
.content {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 精选推荐卡片 */
.featured-card {
  position: relative;
  width: 100%;
  height: 350rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.featured-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1a56db, #1e3a5f);
}

.featured-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0.1));
}

.featured-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 28rpx;
}

.featured-badge {
  display: inline-block;
  background: #FF9800;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
  align-self: flex-start;
}

.featured-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.featured-tag {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

/* 训练卡片网格 */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.train-card {
  width: 48.5%;
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  overflow: hidden;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.card-img {
  height: 250rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-img-icon {
  font-size: 72rpx;
}

.card-info {
  padding: 20rpx;
}

.card-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1c1c;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* 进度卡片 */
.progress-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-top: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.progress-info {
  flex: 1;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1c1c;
  display: block;
  margin-bottom: 10rpx;
}

.progress-desc {
  font-size: 24rpx;
  color: #5f3f3b;
}

.progress-circle {
  margin-left: 24rpx;
}

.circle-bg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: conic-gradient(#1a56db 0deg {{progressDeg}}deg, #f1f1f1 {{progressDeg}}deg 360deg);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.circle-bg::after {
  content: '';
  position: absolute;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #fff;
}

.circle-text {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a56db;
}
