<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-left" bindtap="goBack">
        <text class="nav-icon">←</text>
      </view>
      <view class="nav-title">战训营</view>
      <view class="nav-right">
        <text class="nav-icon">☰</text>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-wrap">
    <view class="search-bar" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索训练操法..." value="{{keyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="onCategoryChange">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 精选推荐卡片（跨两列） -->
    <view class="featured-card">
      <view class="featured-bg"></view>
      <view class="featured-overlay"></view>
      <view class="featured-content">
        <view class="featured-badge">HOT 推荐</view>
        <text class="featured-title">建筑室内综合灭火操法</text>
        <view class="featured-tag">灭火操法</view>
      </view>
    </view>

    <!-- 常规卡片网格 -->
    <view class="card-grid">
      <view class="train-card" wx:for="{{trainings}}" wx:key="id" bindtap="onTrainingTap" data-id="{{item.id}}">
        <view class="card-img" style="background: {{item.bgColor}};">
          <text class="card-img-icon">{{item.icon}}</text>
        </view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <view class="card-tag" style="background: {{item.tagColor}};">{{item.tag}}</view>
        </view>
      </view>
    </view>

    <!-- 学习进度卡片 -->
    <view class="progress-card">
      <view class="progress-info">
        <text class="progress-title">操法学习进度</text>
        <text class="progress-desc">本周已完成 {{completedCount}}/{{totalCount}} 项训练</text>
      </view>
      <view class="progress-circle">
        <view class="circle-bg">
          <text class="circle-text">{{progressPercent}}%</text>
        </view>
      </view>
    </view>
  </view>
</view>
