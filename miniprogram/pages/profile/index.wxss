/** 个人中心页面样式 */

/* 自定义导航 */
.profile-nav {
  padding: 16rpx 24rpx 12rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}
.profile-nav__icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

/* 用户卡片 */
.profile-card {
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}
.profile-card:active {
  opacity: 0.9;
}
.profile-card__avatar--guest {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f1f1f1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-card__points {
  display: inline-flex;
  align-items: center;
  background: rgba(26,86,219,0.08);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* 菜单组 */
.profile-menu-group {
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}
.profile-menu__item {
  height: 100rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  width: 100%;
  box-sizing: border-box;
}
.profile-menu__item:last-child {
  border-bottom: none;
}
.profile-menu__item:active {
  background: #f9f9f9;
}
