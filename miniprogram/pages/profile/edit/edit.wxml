<view class="page-body"><view style="height:{{statusBarHeight}}px;"></view><view class="nav-bar flex items-center justify-between"><view class="nav-back flex items-center justify-center" bindtap="goBack"><text class="nav-back-icon">←</text></view><text class="text-lg font-bold">编辑资料</text><text class="text-md text-primary font-semibold" bindtap="onSave">保存</text></view><view class="edit-form mt-12"><view class="edit-avatar flex flex-col items-center py-24" bindtap="onChangeAvatar"><view class="avatar avatar-lg" style="background:linear-gradient(135deg,#1a56db,#005BAC);"><text style="font-size:52rpx;">{{avatar}}</text></view><text class="text-sm text-secondary mt-8">点击更换头像</text></view><view class="edit-field flex items-center justify-between"><text class="text-sm">姓名</text><input class="edit-input text-sm text-right" value="{{name}}" bindinput="onNameInput"/></view><view class="edit-field flex items-center justify-between"><text class="text-sm">单位</text><input class="edit-input text-sm text-right" value="{{org}}" bindinput="onOrgInput"/></view><view class="edit-field flex items-center justify-between"><text class="text-sm">职务</text><input class="edit-input text-sm text-right" value="{{position}}" bindinput="onPositionInput"/></view><view class="edit-field flex items-center justify-between"><text class="text-sm">手机</text><input class="edit-input text-sm text-right" value="{{phone}}" bindinput="onPhoneInput" type="number"/></view></view><view class="safe-bottom"></view></view>
