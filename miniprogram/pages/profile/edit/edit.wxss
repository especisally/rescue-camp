.page-body{min-height:100vh;background:#f9f9f9}.nav-bar{height:88rpx;padding:0 24rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}.nav-back{width:64rpx;height:64rpx;border-radius:16rpx;background:#f1f1f1}.nav-back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}.edit-form{margin:0 24rpx;background:#fff;border-radius:16rpx;overflow:hidden}.edit-avatar{padding:40rpx 0}.edit-field{padding:24rpx;border-bottom:1rpx solid #f5f5f5}.edit-field:last-child{border-bottom:none}.edit-input{flex:1;margin-left:24rpx;text-align:right;color:#1a1c1c}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}
