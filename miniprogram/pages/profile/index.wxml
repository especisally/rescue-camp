<!-- 我的 - 个人中心 -->
<view class="page-body">

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 自定义顶部导航栏 -->
  <view class="profile-nav flex items-center justify-between">
    <text class="text-lg font-bold">应急救援战训营</text>
    <view class="flex items-center gap-12">
      <view class="profile-nav__icon flex items-center justify-center" bindtap="onSearchTap">
        <text style="font-size:36rpx;">🔍</text>
      </view>
      <view class="profile-nav__icon flex items-center justify-center" bindtap="onSettingsTap">
        <text style="font-size:36rpx;">⚙</text>
      </view>
    </view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="container mt-12">
    <!-- 未登录状态 -->
    <view wx:if="{{!isLoggedIn}}" class="profile-card card-padded" bindtap="toggleLogin">
      <view class="flex items-center">
        <view class="profile-card__avatar--guest">
          <text style="font-size:64rpx;">👤</text>
        </view>
        <view class="ml-12 flex-1">
          <view class="text-lg font-semibold">点击授权登录</view>
          <view class="text-sm text-on-surface-variant mt-4">登录后同步学习进度</view>
        </view>
        <text class="text-on-surface-variant" style="font-size:32rpx;">&gt;</text>
      </view>
    </view>

    <!-- 已登录状态 -->
    <view wx:else class="profile-card card-padded" bindtap="onEditProfile">
      <view class="flex items-center">
        <view class="avatar avatar-lg" style="background: linear-gradient(135deg, #1a56db, #005BAC);">
          <text style="font-size:52rpx;">{{userInfo.avatar}}</text>
        </view>
        <view class="ml-12 flex-1">
          <view class="flex items-center gap-8">
            <text class="text-lg font-bold">{{userInfo.name}}</text>
            <view class="tag tag-secondary text-xs">{{userInfo.badge}}</view>
          </view>
          <view class="text-sm text-on-surface-variant mt-4">ID: {{userInfo.id}}</view>
          <view class="profile-card__points mt-4">
            <text style="font-size:24rpx;">⭐</text>
            <text class="text-sm font-semibold ml-4" style="color:#1a56db;">我的积分: {{userInfo.points}}</text>
          </view>
        </view>
        <text class="text-on-surface-variant" style="font-size:32rpx;">&gt;</text>
      </view>
    </view>
  </view>

  <!-- 菜单组 1 - 我的收藏/评论/上传 -->
  <view class="container mt-12">
    <view class="profile-menu-group card">
      <view wx:for="{{menuGroup1}}" wx:key="id" class="profile-menu__item flex items-center justify-between" bindtap="onMenuTap" data-url="{{item.url}}">
        <view class="flex items-center gap-8">
          <text style="font-size:40rpx;">{{item.icon}}</text>
          <text class="text-md">{{item.name}}</text>
        </view>
        <text class="text-on-surface-variant" style="font-size:28rpx;">&gt;</text>
      </view>
    </view>
  </view>

  <!-- 菜单组 2 - 职业技能鉴定 -->
  <view class="container mt-8">
    <view class="profile-menu-group card">
      <view class="profile-menu__item flex items-center justify-between" bindtap="onMenuTap" data-url="/pages/certification/index">
        <view class="flex items-center gap-8">
          <text style="font-size:40rpx;">✅</text>
          <text class="text-md">职业技能鉴定</text>
        </view>
        <text class="text-on-surface-variant" style="font-size:28rpx;">&gt;</text>
      </view>
    </view>
  </view>

  <!-- 菜单组 3 - 帮助反馈/关于 -->
  <view class="container mt-8">
    <view class="profile-menu-group card">
      <view wx:for="{{menuGroup3}}" wx:key="id" class="profile-menu__item flex items-center justify-between" bindtap="onMenuTap" data-url="{{item.url}}">
        <view class="flex items-center gap-8">
          <text style="font-size:40rpx;">{{item.icon}}</text>
          <text class="text-md">{{item.name}}</text>
        </view>
        <text class="text-on-surface-variant" style="font-size:28rpx;">&gt;</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="container mt-16">
    <view wx:if="{{isLoggedIn}}" class="btn btn-ghost btn-full" style="color:#1a56db; font-size:28rpx;" bindtap="toggleLogin">
      退出登录
    </view>
  </view>

  <!-- 版本号 -->
  <view class="text-xs text-on-surface-variant text-center mt-12" style="opacity:0.5;">
    应急救援战训营 v0.2.5
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom" style="height:40rpx;"></view>

</view>
