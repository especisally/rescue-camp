<!-- 登录 -->
<view class="page-body login-page">

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 自定义顶部导航栏 -->
  <view class="login-nav flex items-center">
    <view class="login-nav__back flex items-center justify-center" bindtap="goBack">
      <text style="font-size:36rpx;">&lt;</text>
    </view>
  </view>

  <!-- Logo 区域 -->
  <view class="login-logo flex flex-col items-center">
    <view class="login-logo__icon flex items-center justify-center">
      <text style="font-size:120rpx;">{{logo}}</text>
    </view>
    <text class="text-2xl font-bold mt-16">{{appName}}</text>
    <text class="text-md text-on-surface-variant mt-8">{{subtitle}}</text>
  </view>

  <!-- 登录按钮 -->
  <view class="container mt-24">
    <view class="login-btn flex items-center justify-center" bindtap="onWechatLogin">
      <text style="font-size:40rpx;">💚</text>
      <text class="text-lg font-semibold ml-8">微信一键登录</text>
    </view>

    <view class="login-skip text-center mt-16" bindtap="onSkipLogin">
      <text class="text-sm text-on-surface-variant">暂不登录</text>
    </view>
  </view>

  <!-- 隐私协议 -->
  <view class="login-agreement text-center">
    <text class="text-xs text-on-surface-variant">
      登录即表示同意
      <text style="color:#1a56db;">《用户协议》</text>
      和
      <text style="color:#1a56db;">《隐私政策》</text>
    </text>
  </view>

  <view class="safe-bottom"></view>
</view>
