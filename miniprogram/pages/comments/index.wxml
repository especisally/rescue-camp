<view class="page-body"><view style="height:{{statusBarHeight}}px;"></view><view class="nav-bar flex items-center justify-between"><view class="nav-back flex items-center justify-center" bindtap="goBack"><text class="nav-back-icon">←</text></view><text class="text-lg font-bold">我的评论</text><view style="width:64rpx;"></view></view><view class="comment-list mt-12" wx:if="{{comments.length>0}}"><view class="comment-item" wx:for="{{comments}}" wx:key="id"><view class="flex items-center gap-8"><text style="font-size:32rpx;">{{item.icon}}</text><text class="text-sm text-on-surface-variant">评论了</text><text class="text-sm font-semibold truncate">{{item.postTitle}}</text></view><view class="comment-item__content mt-8"><text class="text-sm">{{item.myComment}}</text></view><text class="text-xs text-on-surface-variant mt-8">{{item.time}}</text></view></view><view class="comment-empty flex flex-col items-center justify-center" wx:else><text style="font-size:80rpx;">💬</text><text class="text-md text-on-surface-variant mt-16">暂无评论</text></view><view class="safe-bottom"></view></view>
