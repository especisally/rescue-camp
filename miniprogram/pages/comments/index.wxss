.page-body{min-height:100vh;background:#f9f9f9}.nav-bar{height:88rpx;padding:0 24rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}.nav-back{width:64rpx;height:64rpx;border-radius:16rpx;background:#f1f1f1}.nav-back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}.comment-list{padding:0 24rpx;background:#fff}.comment-item{padding:24rpx;background:#fff;margin-bottom:8rpx;border-radius:12rpx}.comment-item__content{padding:12rpx 16rpx;background:#f9f9f9;border-radius:8rpx;border-left:4rpx solid #1a56db}.comment-empty{padding-top:160rpx}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}
