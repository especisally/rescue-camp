.page-body{min-height:100vh;background:#f9f9f9}.nav-bar{height:88rpx;padding:0 24rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}.nav-back{width:64rpx;height:64rpx;border-radius:16rpx;background:#f1f1f1}.nav-back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}.fav-tabs{padding:0 24rpx;background:#fff}.fav-tab{flex:1;text-align:center;padding:20rpx 0;color:#5f3f3b;border-bottom:4rpx solid transparent}.fav-tab.active{color:#1a56db;font-weight:600;border-bottom-color:#1a56db}.fav-list{padding:0 24rpx;background:#fff}.fav-item{padding:20rpx 0;border-bottom:1rpx solid #f5f5f5}.fav-item:last-child{border-bottom:none}.fav-item__icon{width:72rpx;height:72rpx;border-radius:12rpx;flex-shrink:0}.fav-empty{padding-top:160rpx}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}
