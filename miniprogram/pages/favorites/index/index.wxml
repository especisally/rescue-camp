<view class="page-body"><view style="height:{{statusBarHeight}}px;"></view><view class="nav-bar flex items-center justify-between"><view class="nav-back flex items-center justify-center" bindtap="goBack"><text class="nav-back-icon">←</text></view><text class="text-lg font-bold">我的收藏</text><view style="width:64rpx;"></view></view><view class="fav-tabs flex mt-8"><view class="fav-tab text-sm {{activeTab===item.key?'active':''}}" wx:for="{{tabs}}" wx:key="key" bindtap="onTabSwitch" data-tab="{{item.key}}">{{item.name}}</view></view><view class="fav-list mt-12" wx:if="{{items.length>0}}"><view class="fav-item flex items-center gap-8" wx:for="{{items}}" wx:key="id"><view class="fav-item__icon flex items-center justify-center" style="background:{{item.bg}}"><text style="font-size:36rpx;">{{item.icon}}</text></view><view class="flex-1"><text class="text-sm font-semibold truncate">{{item.title}}</text><text class="text-xs text-on-surface-variant">{{item.subtitle}}</text></view><text class="text-on-surface-variant">›</text></view></view><view class="fav-empty flex flex-col items-center justify-center" wx:else><text style="font-size:80rpx;">⭐</text><text class="text-md text-on-surface-variant mt-16">暂无收藏</text></view><view class="safe-bottom"></view></view>
