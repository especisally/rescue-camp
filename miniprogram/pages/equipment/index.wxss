/* pages/equipment/index.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f9f9f9;
  overflow: hidden;
}

/* 导航栏 */
.custom-nav {
  background: #1a56db;
  flex-shrink: 0;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 32rpx;
  color: #fff;
  margin-left: 12rpx;
}

.nav-icon-red {
  color: #FF9800;
}

.nav-left .nav-icon {
  font-size: 36rpx;
  margin-left: 0;
}

.nav-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  display: flex;
  align-items: center;
}

/* 分栏布局 */
.split-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 左侧边栏 */
.sidebar {
  width: 160rpx;
  max-width: 160rpx;
  background: #fff;
  border-right: 1rpx solid #eee;
  flex-shrink: 0;
  box-sizing: border-box;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  border-bottom: 1rpx solid #f9f9f9;
  transition: all 0.2s;
  box-sizing: border-box;
}

.sidebar-item.active {
  background: rgba(0, 91, 172, 0.06);
  border-left: 4rpx solid #005BAC;
}

.sidebar-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.sidebar-text {
  font-size: 22rpx;
  color: #5f3f3b;
  text-align: center;
}

.sidebar-item.active .sidebar-text {
  color: #005BAC;
  font-weight: 600;
}

/* 右侧主区域 */
.main-area {
  flex: 1;
  min-width: 0;
  background: #f9f9f9;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-wrap {
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f1f1f1;
  border-radius: 32rpx;
  padding: 14rpx 20rpx;
}

.search-icon {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #1a1c1c;
}

/* 列表头 */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f1f1f1;
}

.list-count {
  font-size: 24rpx;
  color: #5f3f3b;
}

.list-toggle {
  display: flex;
  gap: 16rpx;
}

.toggle-icon {
  font-size: 32rpx;
  color: #ccc;
}

.toggle-icon.active {
  color: #1a56db;
}

/* 器材列表 */
.equipment-list {
  padding: 16rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.equip-card {
  display: flex;
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.equip-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.equip-img-icon {
  font-size: 72rpx;
}

.equip-info {
  flex: 1;
  padding: 20rpx;
  position: relative;
}

.equip-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1c1c;
  display: block;
  margin-bottom: 6rpx;
}

.equip-model {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.equip-desc {
  font-size: 22rpx;
  color: #5f3f3b;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.equip-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.equip-tag {
  font-size: 18rpx;
  color: #005BAC;
  background: rgba(0, 91, 172, 0.08);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.equip-status {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #999;
}

