/* 拓展学习 样式 */

/* 导航栏 */
.learning-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--color-surface);
  border-bottom: 1rpx solid var(--color-surface-variant);
  height: 88rpx;
}
.learning-nav__back,
.learning-nav__search {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
}
.learning-nav__back:active,
.learning-nav__search:active {
  background: var(--color-surface-variant);
}

/* 筛选标签 */
.learning-filters {
  white-space: nowrap;
}
.learning-filters__inner {
  display: flex;
  padding-bottom: 8rpx;
}
.learning-filter__item {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  background: #e8e8e8;
  color: var(--color-on-surface-variant);
  transition: all 0.2s;
}
.learning-filter__item--active {
  background: var(--color-secondary);
  color: #ffffff;
}

/* 精选大图 */
.learning-feature {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.learning-feature__hero {
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.learning-feature__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 24rpx;
}
.learning-feature__play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  border: 2rpx solid rgba(255,255,255,0.5);
}

/* 视频卡片 */
.learning-video-card__thumb {
  position: relative;
  aspect-ratio: 4/3;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8e8e8;
  overflow: hidden;
}
.learning-video-card__duration {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

/* 资料卡片 */
.learning-doc {
  transition: all 0.2s;
}
.learning-doc:active {
  background: #f1f1f1;
}
.learning-doc__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.learning-doc__download {
  width: 64rpx;
  height: 64rpx;
  color: var(--color-tertiary);
}

/* 趋势网格 */
.learning-trends {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 240rpx 160rpx;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}
.learning-trends__main {
  grid-row: span 2;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}
.learning-trends__badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(4px);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  margin-top: 16rpx;
}
.learning-trends__watermark {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  font-size: 200rpx;
  opacity: 0.1;
  color: #fff;
}
.learning-trends__stat {
  border-radius: var(--radius-lg);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
