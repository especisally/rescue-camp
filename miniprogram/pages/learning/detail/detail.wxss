.detail-page{min-height:100vh;background:#f9f9f9}
.detail-nav{background:#fff;border-bottom:1rpx solid #f0f0f0}
.detail-nav__inner{display:flex;align-items:center;justify-content:space-between;height:88rpx;padding:0 24rpx}
.detail-nav__back{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;background:#f1f1f1}
.detail-nav__back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}
.detail-nav__title{color:#1a1c1c;flex:1;text-align:center}
.detail-nav__placeholder{width:64rpx}
.detail-scroll{height:calc(100vh - 88rpx)}
.media-hero{width:100%;aspect-ratio:16/9;position:relative}
.media-hero__overlay{position:absolute;inset:0;background:rgba(0,0,0,0.3)}
.media-hero__play{width:100rpx;height:100rpx;border-radius:50%;background:rgba(0,0,0,0.5)}
.media-hero__info{position:absolute;bottom:12rpx;right:12rpx}
.media-hero__duration{padding:4rpx 12rpx;background:rgba(0,0,0,0.6);color:#fff;font-size:22rpx;border-radius:8rpx}
.doc-hero{height:400rpx;position:relative;background:rgba(26,86,219,0.1)}
.doc-hero__format{position:absolute;bottom:24rpx;right:24rpx;padding:8rpx 16rpx;background:rgba(0,0,0,0.6);color:#fff;font-size:24rpx;border-radius:8rpx}
.info-section{padding:24rpx;background:#fff;margin:16rpx 24rpx;border-radius:16rpx}
.info-title{color:#1a1c1c;line-height:1.4}
.content-section{padding:24rpx;background:#fff;margin:0 24rpx;border-radius:16rpx}
.content-text{color:#5f3f3b;line-height:1.8;white-space:pre-wrap}
.related-section{padding:24rpx;background:#fff;margin:16rpx 24rpx;border-radius:16rpx}
.section-label{color:#1a1c1c}
.related-item{padding:16rpx 0;border-bottom:1rpx solid #f5f5f5}
.related-item:last-child{border-bottom:none}
.related-item__thumb{width:80rpx;height:80rpx;border-radius:12rpx;flex-shrink:0}
