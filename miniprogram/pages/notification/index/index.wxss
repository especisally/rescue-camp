/** 通知中心页面样式 */

/* ========== 页面容器 ========== */
.notification-page {
  min-height: 100vh;
  background: var(--color-background);
}

/* ========== 自定义导航 ========== */
.notification-nav {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  height: 88rpx;
  box-sizing: border-box;
}

.notification-nav__back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

.notification-nav__action {
  padding: 8rpx 16rpx;
}

.notification-nav__action:active {
  opacity: 0.7;
}

/* ========== 通知列表 ========== */
.notification-list {
  background: #ffffff;
}

.notification-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
  box-sizing: border-box;
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-item:active {
  background: #f9f9f9;
}

.notification-item__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f1f1f1;
  flex-shrink: 0;
  position: relative;
}

.notification-item__dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  background: #f44336;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* ========== 空状态 ========== */
.notification-empty {
  padding-top: 200rpx;
}
