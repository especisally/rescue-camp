<!-- 职业技能鉴定 -->
<view class="page-body cert-page">

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 自定义顶部导航栏 -->
  <view class="cert-nav flex items-center">
    <view class="cert-nav__back flex items-center justify-center" bindtap="goBack">
      <text style="font-size:36rpx;">&lt;</text>
    </view>
    <text class="text-lg font-bold" style="flex:1; text-align:center; margin-right:60rpx;">职业技能鉴定</text>
  </view>

  <!-- 页面标题 -->
  <view class="container mt-12">
    <view class="cert-header card-padded text-center">
      <text style="font-size:64rpx;">📋</text>
      <view class="mt-8">
        <text class="text-lg font-bold">消防员职业技能鉴定</text>
      </view>
      <text class="text-sm text-on-surface-variant mt-4">国家职业资格目录 · 准入类</text>
      <view class="cert-header__current mt-8">
        <text class="text-sm">您当前等级：</text>
        <text class="text-md font-bold text-primary">{{currentLevel}}</text>
      </view>
    </view>
  </view>

  <!-- 等级卡片列表 -->
  <view class="container mt-12">
    <view
      class="cert-card card-padded mt-8"
      wx:for="{{levels}}"
      wx:key="id"
      style="border-left: 8rpx solid {{item.color}};"
    >
      <!-- 等级头部 -->
      <view class="flex items-center justify-between">
        <view class="flex items-center gap-8">
          <text style="font-size:48rpx;">{{item.emoji}}</text>
          <view>
            <view class="flex items-center gap-8">
              <text class="text-md font-bold">{{item.name}}</text>
              <view class="tag tag-primary text-xs" wx:if="{{item.achieved}}">已获得</view>
            </view>
            <text class="text-xs text-on-surface-variant">国家职业资格{{item.grade}}</text>
          </view>
        </view>
      </view>

      <!-- 等级详情 -->
      <view class="cert-card__detail mt-12">
        <view class="cert-card__row flex items-start">
          <text class="text-xs font-semibold cert-card__label">申报条件</text>
          <text class="text-sm text-on-surface-variant flex-1">{{item.requirements}}</text>
        </view>
        <view class="cert-card__row flex items-start mt-8">
          <text class="text-xs font-semibold cert-card__label">考核科目</text>
          <text class="text-sm text-on-surface-variant flex-1">{{item.subjects}}</text>
        </view>
        <view class="cert-card__row flex items-start mt-8">
          <text class="text-xs font-semibold cert-card__label">有效期</text>
          <text class="text-sm text-on-surface-variant flex-1">{{item.validity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
