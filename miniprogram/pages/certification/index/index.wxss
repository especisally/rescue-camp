/** 职业技能鉴定页面样式 */

/* ========== 页面容器 ========== */
.cert-page {
  min-height: 100vh;
  background: var(--color-background);
}

/* ========== 自定义导航 ========== */
.cert-nav {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  height: 88rpx;
  box-sizing: border-box;
}

.cert-nav__back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

/* ========== 页面标题 ========== */
.cert-header__current {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(26, 86, 219, 0.08);
  border-radius: 12rpx;
}

/* ========== 等级卡片 ========== */
.cert-card__detail {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cert-card__row {
  gap: 16rpx;
}

.cert-card__label {
  width: 120rpx;
  flex-shrink: 0;
  color: var(--color-on-surface);
}
