<!-- 视频学习 - 播放页 -->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">←</text>
      </view>
      <text class="nav-title">视频详情</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 视频播放器占位 -->
  <view class="video-container" style="margin-top: calc(88rpx + {{statusBarHeight}}px);">
    <view class="video-placeholder">
      <text class="play-btn">▶</text>
      <text class="play-hint">点击播放</text>
    </view>
  </view>

  <!-- 视频信息 -->
  <view class="video-info">
    <text class="video-title">{{video.title}}</text>
    <view class="video-meta">
      <text class="meta-text">{{video.views}}播放</text>
      <text class="meta-divider">·</text>
      <text class="meta-text">{{video.duration}}</text>
      <text class="meta-divider">·</text>
      <text class="meta-text">{{video.date}}</text>
    </view>
    <view class="video-tags">
      <text class="tag tag-red" wx:for="{{video.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
    </view>
  </view>

  <!-- 作者信息 -->
  <view class="author-card">
    <view class="author-avatar">
      <text class="author-avatar-text">{{video.author ? video.author[0] : '教'}}</text>
    </view>
    <view class="author-info">
      <text class="author-name">{{video.author}}</text>
      <text class="author-level">{{video.level}}</text>
    </view>
    <view class="follow-btn">
      <text class="follow-text">+ 关注</text>
    </view>
  </view>

  <!-- 简介 -->
  <view class="desc-section">
    <text class="desc-text {{descExpanded ? 'desc-expanded' : ''}}">{{video.description}}</text>
    <text class="desc-toggle" bindtap="toggleDesc">
      {{descExpanded ? '收起' : '展开'}}
    </text>
  </view>

  <!-- 相关推荐 -->
  <view class="section-header">
    <text class="section-title">相关推荐</text>
  </view>

  <view class="related-list">
    <view class="related-card" wx:for="{{relatedVideos}}" wx:key="id" bindtap="onRelatedTap" data-id="{{item.id}}">
      <view class="related-thumb" style="background-color: {{item.thumbColor}};">
        <text class="related-duration">{{item.duration}}</text>
      </view>
      <view class="related-info">
        <text class="related-title">{{item.title}}</text>
        <text class="related-meta">{{item.views}}播放 · {{item.date}}</text>
      </view>
    </view>
  </view>
</view>
