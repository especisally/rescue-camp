<!-- 视频分类详情 -->
<view class="page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">←</text>
      </view>
      <text class="nav-title">{{categoryName}}</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-wrap" style="margin-top: calc(88rpx + {{statusBarHeight}}px);">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索{{categoryName}}相关视频..." value="{{keyword}}" bindinput="onSearchInput" placeholder-class="search-placeholder" />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-item {{activeFilter === item.id ? 'active' : ''}}" wx:for="{{filterTags}}" wx:key="id" data-id="{{item.id}}" bindtap="onFilterChange">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 视频列表 -->
  <view class="video-list">
    <block wx:if="{{filteredList.length > 0}}">
      <view class="video-card" wx:for="{{filteredList}}" wx:key="id" bindtap="onVideoTap" data-id="{{item.id}}">
        <view class="video-thumb" style="background: {{item.thumbBg}};">
          <view class="video-play-btn">
            <text>▶</text>
          </view>
          <view class="video-duration">{{item.duration}}</view>
          <view class="video-points" wx:if="{{item.points > 0}}">{{item.points}}积分</view>
        </view>
        <view class="video-info">
          <text class="video-title">{{item.title}}</text>
          <view class="video-meta">
            <text class="video-author">{{item.author}}</text>
            <text class="video-views">{{item.views}}次播放</text>
          </view>
          <view class="video-tags-row">
            <text class="video-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredList.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无相关视频</text>
      <text class="empty-hint">换个关键词试试</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
