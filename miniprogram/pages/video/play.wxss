/* 视频学习 - 播放页样式 */
page {
  background-color: #f9f9f9;
}

.page {
  padding-bottom: 40rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background-color: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #1a1c1c;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1c1c;
}

.nav-placeholder {
  width: 60rpx;
  height: 60rpx;
}

/* 视频播放器 */
.video-container {
  margin-top: 88rpx;
  width: 100%;
}

.video-placeholder {
  width: 100%;
  height: 422rpx;
  background-color: #333;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.play-btn {
  font-size: 72rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.play-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 视频信息 */
.video-info {
  background-color: #fff;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.video-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1c1c;
  line-height: 1.4;
}

.video-meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.meta-divider {
  margin: 0 10rpx;
  font-size: 24rpx;
  color: #ccc;
}

.video-tags {
  display: flex;
  margin-top: 16rpx;
  gap: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.tag-red {
  background-color: rgba(26, 86, 219, 0.1);
  color: #1a56db;
}

.tag-blue {
  background-color: rgba(0, 91, 172, 0.1);
  color: #005BAC;
}

/* 作者信息 */
.author-card {
  margin: 16rpx 24rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1a56db;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.author-avatar-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1c1c;
}

.author-level {
  font-size: 22rpx;
  color: #1a56db;
  margin-top: 4rpx;
}

.follow-btn {
  border: 2rpx solid #1a56db;
  border-radius: 32rpx;
  padding: 10rpx 28rpx;
}

.follow-text {
  font-size: 24rpx;
  color: #1a56db;
  font-weight: bold;
}

/* 简介 */
.desc-section {
  margin: 0 24rpx 16rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #5f3f3b;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.desc-text.desc-expanded {
  display: block;
  overflow: visible;
}

.desc-toggle {
  font-size: 26rpx;
  color: #005BAC;
  margin-top: 12rpx;
  display: block;
}

/* 分区标题 */
.section-header {
  padding: 32rpx 24rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1c1c;
}

/* 相关推荐 */
.related-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.related-card {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.related-thumb {
  width: 200rpx;
  height: 130rpx;
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.related-duration {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.related-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.related-title {
  font-size: 28rpx;
  color: #1a1c1c;
  line-height: 1.4;
}

.related-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
