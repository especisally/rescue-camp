/* 视频分类详情页样式 */
page {
  background-color: #f9f9f9;
}

.page {
  min-height: 100vh;
}

/* 自定义导航栏 */
.custom-nav {
  background-color: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #1a1c1c;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a56db;
  flex: 1;
  text-align: center;
}

.nav-placeholder {
  width: 60rpx;
  height: 60rpx;
}

/* 搜索栏 */
.search-wrap {
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f1f1f1;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f1f1f1;
  border-radius: 32rpx;
  padding: 14rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1a1c1c;
}

.search-placeholder {
  color: #bbb;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  margin-left: 8rpx;
}

/* 筛选标签 */
.filter-bar {
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f1f1f1;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5f3f3b;
  background: #f1f1f1;
}

.filter-item.active {
  color: #fff;
  background: #1a56db;
}

/* 视频列表 */
.video-list {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.video-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.video-card:active {
  transform: scale(0.98);
  transition: transform 0.15s ease;
}

.video-thumb {
  position: relative;
  width: 100%;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a3a5c, #2c5f8a);
}

.video-play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
}

.video-duration {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.7);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.video-points {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #FF9800;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.video-info {
  padding: 20rpx 24rpx 24rpx;
}

.video-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1c1c;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.video-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 24rpx;
}

.video-author {
  font-size: 24rpx;
  color: #1a56db;
}

.video-views {
  font-size: 24rpx;
  color: #999;
}

.video-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.video-tag {
  font-size: 20rpx;
  color: #1a56db;
  background: rgba(26,86,219,0.08);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #5f3f3b;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 底部安全区 */
.safe-bottom {
  height: 120rpx;
}
