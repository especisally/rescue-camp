.page-body{min-height:100vh;background:#f9f9f9}.nav-bar{height:88rpx;padding:0 24rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}.nav-back{width:64rpx;height:64rpx;border-radius:16rpx;background:#f1f1f1}.nav-back-icon{font-size:36rpx;color:#1a1c1c;font-weight:bold}.upload-list{padding:0 24rpx;background:#fff}.upload-item{padding:20rpx 0;border-bottom:1rpx solid #f5f5f5}.upload-item:last-child{border-bottom:none}.upload-item__icon{width:72rpx;height:72rpx;border-radius:12rpx;background:#f1f1f1;flex-shrink:0}.upload-status{padding:2rpx 12rpx;border-radius:8rpx}.upload-empty{padding-top:160rpx}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}
