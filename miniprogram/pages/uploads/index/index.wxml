<view class="page-body"><view style="height:{{statusBarHeight}}px;"></view><view class="nav-bar flex items-center justify-between"><view class="nav-back flex items-center justify-center" bindtap="goBack"><text class="nav-back-icon">←</text></view><text class="text-lg font-bold">我的上传</text><view style="width:64rpx;"></view></view><view class="upload-list mt-12" wx:if="{{uploads.length>0}}"><view class="upload-item flex items-center gap-12" wx:for="{{uploads}}" wx:key="id"><view class="upload-item__icon flex items-center justify-center"><text style="font-size:40rpx;">{{item.icon}}</text></view><view class="flex-1"><text class="text-sm font-semibold truncate">{{item.title}}</text><view class="flex items-center gap-12 mt-4"><text class="text-xs text-on-surface-variant">{{item.type}} · {{item.time}}</text><view class="upload-status text-xs" style="background:{{item.status==='published'?'#e8f5e9':item.status==='reviewing'?'#fff3e0':'#fce4ec'}};color:{{item.status==='published'?'#4CAF50':item.status==='reviewing'?'#FF9800':'#ba1a1a'}}">{{item.statusText}}</view></view></view><text class="text-on-surface-variant">›</text></view></view><view class="upload-empty flex flex-col items-center justify-center" wx:else><text style="font-size:80rpx;">📤</text><text class="text-md text-on-surface-variant mt-16">暂无上传内容</text></view><view class="safe-bottom"></view></view>
