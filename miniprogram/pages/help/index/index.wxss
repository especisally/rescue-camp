/** 帮助反馈页面样式 */

/* ========== 页面容器 ========== */
.help-page {
  min-height: 100vh;
  background: var(--color-background);
}

/* ========== 自定义导航 ========== */
.help-nav {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  height: 88rpx;
  box-sizing: border-box;
}

.help-nav__back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

/* ========== FAQ 折叠面板 ========== */
.help-section-title {
  padding: 0 0 8rpx 0;
}

.help-faq {
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.help-faq__item {
  border-bottom: 1rpx solid #f5f5f5;
}

.help-faq__item:last-child {
  border-bottom: none;
}

.help-faq__question {
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.help-faq__question:active {
  background: #f9f9f9;
}

.help-faq__arrow {
  transition: transform 0.2s;
  flex-shrink: 0;
}

.help-faq__arrow--expanded {
  transform: rotate(90deg);
}

.help-faq__answer {
  padding: 0 24rpx 28rpx 56rpx;
  box-sizing: border-box;
}

/* ========== 意见反馈 ========== */
.help-feedback__textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--color-on-surface);
  box-sizing: border-box;
  border: none;
  outline: none;
}
