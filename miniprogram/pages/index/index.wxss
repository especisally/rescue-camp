/** 首页样式 */

/* 自定义导航栏 */
.index-nav {
  display: flex;
  flex-direction: column;
  padding: 16rpx 24rpx 12rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}
.index-nav__title {
  text-align: center;
  margin-bottom: 12rpx;
  color: #1a56db;
}
.index-nav__filter {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
  flex-shrink: 0;
}

/* Banner */
.index-banner {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.index-banner__item {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: flex-end;
}
.index-banner__overlay {
  width: 100%;
  padding: 32rpx 32rpx 40rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
}
.index-banner__icon {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}
.index-banner__subtitle {
  opacity: 0.85;
}

/* 功能网格 */
.index-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.index-grid__card {
  width: calc((100% - 48rpx) / 3);
  background: #ffffff;
  border: 1rpx solid #e2e2e2;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}
.index-grid__card:active {
  opacity: 0.8;
  transform: scale(0.97);
}
.index-grid__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
.index-grid__name {
  color: #1a1c1c;
}
.index-grid__desc {
  opacity: 0.7;
}

/* 推荐区域 */
.index-recommend__hero {
  width: 100%;
  height: 340rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}
.index-recommend__hero-icon {
  font-size: 120rpx;
}
.index-recommend__row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}
.index-recommend__thumb {
  width: 220rpx;
  min-height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 12rpx 0 0 12rpx;
}
