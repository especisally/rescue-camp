<!-- 全局搜索结果页 -->
<view class="page-body search-page">

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 搜索导航栏 -->
  <view class="search-nav">
    <view class="search-nav__inner">
      <view class="search-nav__input-wrap">
        <text class="search-nav__icon">🔍</text>
        <input class="search-nav__input"
               placeholder="搜索课程、帖子、商品、装备..."
               placeholder-class="search-nav__placeholder"
               value="{{keyword}}"
               bindinput="onSearchInput"
               bindconfirm="onSearchConfirm"
               confirm-type="search"
               focus="{{true}}" />
        <view class="search-nav__clear flex items-center justify-center" wx:if="{{keyword}}" bindtap="onClearKeyword">
          <text style="font-size:28rpx; color: #999;">✕</text>
        </view>
      </view>
      <text class="search-nav__cancel text-md text-primary" bindtap="goBack">取消</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="search-tabs">
    <view class="search-tabs__item {{activeTab === item.key ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="key"
          bindtap="onTabSwitch" data-tab="{{item.key}}">
      {{item.name}}
      <view class="search-tabs__indicator" wx:if="{{activeTab === item.key}}"></view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{showHistory && history.length > 0}}">
    <view class="search-history__header flex items-center justify-between">
      <text class="text-md font-bold">搜索历史</text>
      <view class="flex items-center gap-4" bindtap="onClearHistory">
        <text style="font-size:28rpx;">🗑️</text>
        <text class="text-sm text-on-surface-variant">清除</text>
      </view>
    </view>
    <view class="search-history__tags mt-12">
      <view class="search-history__tag" wx:for="{{history}}" wx:key="*this" bindtap="onHistoryTap" data-keyword="{{item}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 搜索结果列表 -->
  <view class="search-results" wx:if="{{hasSearched}}">
    <view class="search-results__count text-sm text-on-surface-variant" wx:if="{{results.length > 0}}">
      找到 {{results.length}} 个相关结果
    </view>

    <!-- 结果列表 -->
    <view class="search-results__list mt-8">
      <view class="search-result flex items-center gap-12" wx:for="{{results}}" wx:key="id" bindtap="onResultTap" data-index="{{index}}">
        <view class="search-result__icon flex items-center justify-center" style="background: {{item.bg}};">
          <text style="font-size:40rpx;">{{item.icon}}</text>
        </view>
        <view class="flex-1" style="overflow:hidden;">
          <text class="text-sm font-semibold truncate">{{item.title}}</text>
          <text class="text-xs text-on-surface-variant mt-4">{{item.subtitle}}</text>
        </view>
        <text class="text-on-surface-variant" style="font-size:28rpx;">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="search-empty flex flex-col items-center justify-center" wx:if="{{results.length === 0}}">
      <text style="font-size:80rpx;">🔍</text>
      <text class="text-md text-on-surface-variant mt-16">未找到相关内容</text>
      <text class="text-sm text-on-surface-variant mt-8">换个关键词试试</text>
    </view>
  </view>

  <!-- 初始状态（无历史、未搜索） -->
  <view class="search-placeholder flex flex-col items-center justify-center" wx:if="{{!showHistory && !hasSearched || (showHistory && history.length === 0 && !hasSearched)}}">
    <text style="font-size:80rpx;">🔍</text>
    <text class="text-md text-on-surface-variant mt-16">输入关键词开始搜索</text>
    <text class="text-sm text-on-surface-variant mt-8">支持课程、帖子、商品、装备</text>
  </view>

  <view class="safe-bottom"></view>
</view>
