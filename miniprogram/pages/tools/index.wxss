/* pages/tools/index.wxss */
.page {
  min-height: 100vh;
  background: #f9f9f9;
  padding-bottom: 40rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background: #1a56db;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 36rpx;
  color: #fff;
}

.nav-center {
  flex: 1;
  margin: 0 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 内容区域 */
.content {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

/* Hero 网格 2列 */
.hero-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

/* Hero 卡片 */
.hero-card {
  position: relative;
  width: 48.5%;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  display: block;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
}

.card-primary {
  background: linear-gradient(135deg, #1a56db, #1e3a5f);
}

.card-blue {
  background: linear-gradient(135deg, #005BAC, #003D7A);
}

.card-gray {
  background: linear-gradient(135deg, #4A4A4A, #2C2C2C);
}

.card-green {
  background: linear-gradient(135deg, #2E7D32, #1B5E20);
}

.card-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 32rpx;
}

.card-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  color: #fff;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  text-align: center;
  line-height: 1.4;
}

/* 常用换算与参考 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1c1c;
  margin: 32rpx 0 20rpx;
}

.quick-tools {
  display: flex;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

.quick-card {
  width: 48.5%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f1f1f1;
  border-radius: 12rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.quick-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.quick-label {
  font-size: 26rpx;
  color: #1a1c1c;
  font-weight: 500;
}
