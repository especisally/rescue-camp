/* pages/tools/standard-detail.wxss */
.page {
  min-height: 100vh;
  background: #f9f9f9;
}

/* 导航栏 */
.custom-nav {
  background: #1a56db;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 36rpx;
  color: #fff;
}

.nav-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  width: 60rpx;
}

/* 内容 */
.content {
  padding: 24rpx;
  padding-bottom: 60rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1c1c;
  margin-bottom: 20rpx;
}

.info-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.meta-value {
  font-size: 24rpx;
  color: #1a1c1c;
  font-weight: 500;
}

.info-scope {
  display: flex;
  align-items: baseline;
}

.scope-label {
  font-size: 24rpx;
  color: #5f3f3b;
  flex-shrink: 0;
}

.scope-text {
  font-size: 24rpx;
  color: #1a1c1c;
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1c1c;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #1a56db;
}

/* 考核项目 */
.project-list {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.project-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.project-item:last-child {
  border-bottom: none;
}

.project-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #005BAC;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.project-body {
  flex: 1;
}

.project-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1c1c;
  display: block;
  margin-bottom: 8rpx;
}

.project-scores {
  display: flex;
  gap: 24rpx;
}

.score-pass {
  font-size: 24rpx;
  color: #FF9800;
}

.score-excellent {
  font-size: 24rpx;
  color: #2E7D32;
}

/* 评分标准 */
.score-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
}

.score-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.score-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #1a56db;
}

.score-num.pass {
  color: #FF9800;
}

.score-num.excellent {
  color: #2E7D32;
}

.score-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.score-note {
  font-size: 24rpx;
  color: #5f3f3b;
  text-align: center;
  line-height: 1.5;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f1f1;
}

/* 下载按钮 */
.download-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a56db;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-top: 24rpx;
}

.download-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.download-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
