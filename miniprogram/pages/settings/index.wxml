<!-- 设置 -->
<view class="page-body settings-page">

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 自定义顶部导航栏 -->
  <view class="settings-nav flex items-center">
    <view class="settings-nav__back flex items-center justify-center" bindtap="goBack">
      <text style="font-size:36rpx;">&lt;</text>
    </view>
    <text class="text-lg font-bold" style="flex:1; text-align:center; margin-right:60rpx;">设置</text>
  </view>

  <!-- 开关设置组 -->
  <view class="container mt-12">
    <view class="settings-group card">
      <view
        class="settings-group__item flex items-center justify-between"
        wx:for="{{switchItems}}"
        wx:key="id"
      >
        <view class="flex items-center gap-12">
          <text style="font-size:40rpx;">{{item.icon}}</text>
          <text class="text-md">{{item.name}}</text>
        </view>
        <switch
          checked="{{item.value}}"
          data-id="{{item.id}}"
          bindchange="onSwitchChange"
          color="#1a56db"
        />
      </view>
    </view>
  </view>

  <!-- 普通菜单组 -->
  <view class="container mt-8">
    <view class="settings-group card">
      <view
        class="settings-group__item flex items-center justify-between"
        wx:for="{{menuItems}}"
        wx:key="id"
        bindtap="onMenuTap"
        data-id="{{item.id}}"
        data-url="{{item.url}}"
      >
        <view class="flex items-center gap-12">
          <text style="font-size:40rpx;">{{item.icon}}</text>
          <text class="text-md">{{item.name}}</text>
        </view>
        <view class="flex items-center gap-8">
          <text wx:if="{{item.id === 'cache'}}" class="text-sm text-on-surface-variant">{{cacheSize}}</text>
          <text class="text-on-surface-variant" style="font-size:28rpx;">&gt;</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="container mt-24">
    <view class="btn btn-ghost btn-full" style="color:#ba1a1a; font-size:28rpx;" bindtap="onLogout">
      退出登录
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
