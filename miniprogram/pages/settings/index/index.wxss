/** 设置页面样式 */

/* ========== 页面容器 ========== */
.settings-page {
  min-height: 100vh;
  background: var(--color-background);
}

/* ========== 自定义导航 ========== */
.settings-nav {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  height: 88rpx;
  box-sizing: border-box;
}

.settings-nav__back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f1f1f1;
}

/* ========== 设置组 ========== */
.settings-group {
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.settings-group__item {
  height: 100rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}

.settings-group__item:last-child {
  border-bottom: none;
}

.settings-group__item:active {
  background: #f9f9f9;
}
