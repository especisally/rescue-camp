/** 全局样式 - 应急救援战训营 **/

/* 全局 box-sizing 修复 - 防止边框和内边距导致元素溢出 */
view, scroll-view, swiper, swiper-item, navigator, image, text, input, textarea, button, canvas, block {
  box-sizing: border-box;
}

/* 设计令牌 (Design Tokens) */
page {
  --color-primary: #1a56db;
  --color-primary-dark: #1e40af;
  --color-secondary: #0284c7;
  --color-secondary-dark: #0369a1;
  --color-tertiary: #5a5a5a;
  --color-background: #f9f9f9;
  --color-surface: #ffffff;
  --color-surface-variant: #e2e2e2;
  --color-on-surface: #1a1c1c;
  --color-on-surface-variant: #5f3f3b;
  --color-error: #ba1a1a;
  --color-outline: #946e69;
  --color-outline-variant: #e9bcb6;

  --spacing-gutter: 24rpx;
  --spacing-stack-sm: 8rpx;
  --spacing-stack-md: 16rpx;
  --spacing-section: 24rpx;
  --spacing-container: 24rpx;

  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-full: 24px;

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;

  background-color: var(--color-background);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: var(--font-md);
  color: var(--color-on-surface);
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 0 var(--spacing-container);
  box-sizing: border-box;
}

/* Flex 布局工具 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-end { justify-content: flex-end; }

/* 间距 */
.mt-4 { margin-top: 8rpx; }
.mt-8 { margin-top: 16rpx; }
.mt-12 { margin-top: 24rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-4 { margin-bottom: 8rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-12 { margin-bottom: 24rpx; }
.mb-16 { margin-bottom: 32rpx; }
.ml-4 { margin-left: 8rpx; }
.ml-8 { margin-left: 16rpx; }
.mr-4 { margin-right: 8rpx; }
.mr-8 { margin-right: 16rpx; }
.p-8 { padding: 16rpx; }
.p-12 { padding: 24rpx; }
.p-16 { padding: 32rpx; }
.px-8 { padding-left: 16rpx; padding-right: 16rpx; }
.px-12 { padding-left: 24rpx; padding-right: 24rpx; }
.px-16 { padding-left: 32rpx; padding-right: 32rpx; }
.py-4 { padding-top: 8rpx; padding-bottom: 8rpx; }
.py-8 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-12 { padding-top: 24rpx; padding-bottom: 24rpx; }
.gap-4 { gap: 8rpx; }
.gap-8 { gap: 16rpx; }
.gap-12 { gap: 24rpx; }
.gap-16 { gap: 32rpx; }

/* 文字 */
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-2xl { font-size: var(--font-2xl); }
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-tertiary { color: var(--color-tertiary); }
.text-on-surface { color: var(--color-on-surface); }
.text-on-surface-variant { color: var(--color-on-surface-variant); }
.text-white { color: #ffffff; }
.text-error { color: var(--color-error); }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.text-center { text-align: center; }
.text-right { text-align: right; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.line-clamp-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

/* 卡片 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-surface-variant);
  overflow: hidden;
}
.card-padded {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-surface-variant);
  padding: 24rpx;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: var(--font-md);
  padding: 16rpx 32rpx;
  transition: all 0.2s;
  border: none;
}
.btn:active { opacity: 0.8; transform: scale(0.97); }
.btn-primary { background: var(--color-primary); color: #ffffff; }
.btn-secondary { background: var(--color-secondary); color: #ffffff; }
.btn-outline { background: transparent; border: 1rpx solid var(--color-surface-variant); color: var(--color-on-surface); }
.btn-ghost { background: transparent; color: var(--color-on-surface-variant); }
.btn-sm { font-size: var(--font-sm); padding: 8rpx 24rpx; }
.btn-lg { font-size: var(--font-lg); padding: 20rpx 40rpx; }
.btn-full { width: 100%; }
.btn-round { border-radius: var(--radius-full); }

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}
.tag-primary { background: rgba(26, 86, 219, 0.1); color: var(--color-primary); }
.tag-secondary { background: rgba(0, 91, 172, 0.1); color: var(--color-secondary); }
.tag-outline { background: var(--color-background); border: 1rpx solid var(--color-surface-variant); }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-surface-variant);
  margin: 16rpx 0;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #f1f1f1;
  border-radius: var(--radius-md);
  padding: 12rpx 24rpx;
  gap: 16rpx;
}
.search-bar input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-size: var(--font-md);
}

/* 底部安全区 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 隐藏滚动条 */
.hide-scrollbar::-webkit-scrollbar {
  display: none;
}

/* 页面主体 */
.page-body {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 圆形头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-surface-variant);
}
.avatar-sm { width: 60rpx; height: 60rpx; }
.avatar-lg { width: 120rpx; height: 120rpx; }

/* 图标占位 - 用于替代 Material Icons */
.icon {
  font-size: 40rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-sm { font-size: 32rpx; width: 32rpx; height: 32rpx; }
.icon-lg { font-size: 56rpx; width: 56rpx; height: 56rpx; }

/* 底部导航占位高度 */
.tab-bar-placeholder {
  height: 100rpx;
}

/* 网格布局 */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24rpx;
}

/* 吸顶 */
.sticky-top {
  position: sticky;
  top: 0;
  z-index: 50;
}

/* 遮罩层 */
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
}

/* 状态栏占位 */
.status-bar {
  height: var(--status-bar-height, 44px);
}
