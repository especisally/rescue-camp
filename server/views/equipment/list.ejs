<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <form class="row g-2" method="GET">
      <div class="col-md-3">
        <input type="text" name="keyword" class="form-control" placeholder="搜索装备名称..." value="<%= keyword %>">
      </div>
      <div class="col-md-3">
        <select name="categoryId" class="form-select">
          <option value="">全部分类</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= categoryId == c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">搜索</button>
      </div>
      <div class="col-md-4 text-end">
        <a href="/admin/equipment/create" class="btn btn-success">+ 新增装备</a>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th><th>名称</th><th>型号</th><th>分类</th><th>状态</th><th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">暂无数据</td></tr>
        <% } %>
        <% list.forEach(function(e) { %>
          <tr>
            <td><%= e.id %></td>
            <td><strong><%= e.name %></strong></td>
            <td><%= e.model || '-' %></td>
            <td><span class="badge bg-secondary"><%= e.category ? e.category.name : '-' %></span></td>
            <td>
              <% if (e.status === 1) { %><span class="badge bg-success">正常</span><% } %>
              <% if (e.status === 2) { %><span class="badge bg-warning">维修中</span><% } %>
              <% if (e.status === 3) { %><span class="badge bg-danger">报废</span><% } %>
            </td>
            <td>
              <a href="/admin/equipment/<%= e.id %>/edit" class="btn btn-sm btn-outline-primary">编辑</a>
              <form method="POST" action="/admin/equipment/<%= e.id %>/delete" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除？')">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3"><ul class="pagination justify-content-center">
  <% for (var i = 1; i <= totalPages; i++) { %>
    <li class="page-item <%= i === page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&keyword=<%= keyword %>&categoryId=<%= categoryId %>"><%= i %></a></li>
  <% } %>
</ul></nav>
<% } %>
<%- include('../layouts/footer') %>
