<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form method="POST" action="<%= isEdit ? '/admin/videos/' + video.id : '/admin/videos' %>">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">标题 *</label>
          <input type="text" name="title" class="form-control" value="<%= video.title || '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">分类 *</label>
          <select name="categoryId" class="form-select" required>
            <option value="">请选择</option>
            <% categories.forEach(function(c) { %>
              <option value="<%= c.id %>" <%= video.categoryId == c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">封面图片 URL</label>
          <div class="input-group">
            <input type="text" name="coverUrl" class="form-control" value="<%= video.coverUrl || '' %>" placeholder="/uploads/images/xxx.jpg">
            <button type="button" class="btn btn-outline-secondary upload-btn" data-target="coverUrl" data-type="image">📤 上传</button>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label">视频文件 URL</label>
          <div class="input-group">
            <input type="text" name="videoUrl" class="form-control" value="<%= video.videoUrl || '' %>" placeholder="/uploads/videos/xxx.mp4">
            <button type="button" class="btn btn-outline-secondary upload-btn" data-target="videoUrl" data-type="video">📤 上传</button>
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label">作者</label>
          <input type="text" name="author" class="form-control" value="<%= video.author || '' %>">
        </div>
        <!-- 时长由视频上传后自动检测填充 -->
        <input type="hidden" name="duration" value="<%= video.duration || '' %>">
        <div class="col-md-3">
          <label class="form-label">所需积分</label>
          <input type="number" name="points" class="form-control" value="<%= video.points || 0 %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">状态</label>
          <select name="status" class="form-select">
            <option value="1" <%= video.status == 1 ? 'selected' : '' %>>上架</option>
            <option value="0" <%= video.status == 0 ? 'selected' : '' %>>下架</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label">简介</label>
          <textarea name="description" class="form-control" rows="3"><%= video.description || '' %></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">保 存</button>
          <a href="/admin/videos" class="btn btn-secondary ms-2">取 消</a>
        </div>
      </div>
    </form>
  </div>
</div>
<%- include('../layouts/footer') %>
