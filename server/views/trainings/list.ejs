<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <form class="row g-2" method="GET">
      <div class="col-md-3">
        <input type="text" name="keyword" class="form-control" placeholder="搜索操法标题..." value="<%= keyword %>">
      </div>
      <div class="col-md-3">
        <select name="categoryId" class="form-select">
          <option value="">全部分类</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= categoryId == c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">搜索</button>
      </div>
      <div class="col-md-4 text-end">
        <a href="/admin/trainings/create" class="btn btn-success">+ 新增操法</a>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th><th>标题</th><th>分类</th><th>装备清单</th><th>状态</th><th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">暂无数据</td></tr>
        <% } %>
        <% list.forEach(function(t) { %>
          <tr>
            <td><%= t.id %></td>
            <td><%= t.title %></td>
            <td><span class="badge bg-secondary"><%= t.category ? t.category.name : '-' %></span></td>
            <td><%= t.equipment ? (typeof t.equipment === 'string' ? t.equipment : (Array.isArray(t.equipment) ? t.equipment.join(', ') : '-')) : '-' %></td>
            <td><span class="badge <%= t.status === 1 ? 'bg-success' : 'bg-secondary' %>"><%= t.status === 1 ? '上架' : '下架' %></span></td>
            <td>
              <a href="/admin/trainings/<%= t.id %>/edit" class="btn btn-sm btn-outline-primary">编辑</a>
              <form method="POST" action="/admin/trainings/<%= t.id %>/delete" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除？')">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (var i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&keyword=<%= keyword %>&categoryId=<%= categoryId %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
  <p class="text-center text-muted">共 <%= total %> 条，第 <%= page %>/<%= totalPages %> 页</p>
</nav>
<% } %>
<%- include('../layouts/footer') %>
