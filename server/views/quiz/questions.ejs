<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body d-flex justify-content-between align-items-center">
    <span class="fw-bold">📝 <%= bank.title %> — 共 <%= total %> 题</span>
    <a href="/admin/quiz/banks/<%= bank.id %>/questions/create" class="btn btn-success">+ 新增题目</a>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th style="width:50px">ID</th>
          <th>题目</th>
          <th style="width:80px">类型</th>
          <th style="width:100px">正确答案</th>
          <th style="width:150px">操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted py-4">暂无题目</td></tr>
        <% } %>
        <% list.forEach(function(q) { %>
          <tr>
            <td><%= q.id %></td>
            <td><%= q.question %></td>
            <td>
              <% if (q.type === 'single') { %><span class="badge bg-primary">单选</span>
              <% } else if (q.type === 'multi') { %><span class="badge bg-info">多选</span>
              <% } else { %><span class="badge bg-success">判断</span><% } %>
            </td>
            <td><code><%= q.correctAnswer %></code></td>
            <td>
              <a href="/admin/quiz/banks/<%= bank.id %>/questions/<%= q.id %>/edit" class="btn btn-sm btn-outline-primary">编辑</a>
              <form method="POST" action="/admin/quiz/banks/<%= bank.id %>/questions/<%= q.id %>/delete" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除？')">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<a href="/admin/quiz/banks" class="btn btn-secondary mt-3">← 返回题库列表</a>

<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (var i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
<%- include('../layouts/footer') %>
