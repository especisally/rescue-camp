<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body text-end">
    <a href="/admin/quiz/banks/create" class="btn btn-success">+ 新增题库</a>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>标题</th>
          <th>分类</th>
          <th>题目数</th>
          <th>状态</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">暂无题库</td></tr>
        <% } %>
        <% list.forEach(function(bank) { %>
          <tr>
            <td><%= bank.id %></td>
            <td><%= bank.title %></td>
            <td><span class="badge bg-secondary"><%= bank.category ? bank.category.name : '-' %></span></td>
            <td><%= bank._count ? bank._count.questions : bank.questionCount || 0 %></td>
            <td><span class="badge <%= bank.status === 1 ? 'bg-success' : 'bg-secondary' %>"><%= bank.status === 1 ? '启用' : '停用' %></span></td>
            <td>
              <a href="/admin/quiz/banks/<%= bank.id %>/questions" class="btn btn-sm btn-outline-info">题目</a>
              <a href="/admin/quiz/banks/<%= bank.id %>/edit" class="btn btn-sm btn-outline-primary">编辑</a>
              <form method="POST" action="/admin/quiz/banks/<%= bank.id %>/delete" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除？')">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../layouts/footer') %>
