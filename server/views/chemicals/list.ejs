<%- include('../layouts/header') %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <form class="row g-2" method="GET">
      <div class="col-md-4">
        <input type="text" name="keyword" class="form-control" placeholder="搜索危化品名称..." value="<%= keyword %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">搜索</button>
      </div>
      <div class="col-md-6 text-end">
        <a href="/admin/chemicals/create" class="btn btn-success">+ 新增危化品</a>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th><th>名称</th><th>分子式</th><th>UN编号</th><th>危险类别</th><th>状态</th><th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr>
        <% } %>
        <% list.forEach(function(c) { %>
          <tr>
            <td><%= c.id %></td>
            <td><strong><%= c.name %></strong></td>
            <td><%= c.formula || '-' %></td>
            <td><%= c.unNumber || '-' %></td>
            <td><%= c.hazardClass || '-' %></td>
            <td><span class="badge <%= c.status === 1 ? 'bg-success' : 'bg-secondary' %>"><%= c.status === 1 ? '上架' : '下架' %></span></td>
            <td>
              <a href="/admin/chemicals/<%= c.id %>/edit" class="btn btn-sm btn-outline-primary">编辑</a>
              <form method="POST" action="/admin/chemicals/<%= c.id %>/delete" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确认删除？')">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (var i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&keyword=<%= keyword %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
  <p class="text-center text-muted">共 <%= total %> 条，第 <%= page %>/<%= totalPages %> 页</p>
</nav>
<% } %>
<%- include('../layouts/footer') %>
