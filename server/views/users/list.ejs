<%- include('../layouts/header') %>

<!-- 搜索 -->
<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <form class="row g-2" method="GET">
      <div class="col-md-4">
        <input type="text" name="keyword" class="form-control" placeholder="搜索昵称/手机号..." value="<%= keyword %>">
      </div>
      <div class="col-md-3">
        <select name="role" class="form-select">
          <option value="">全部角色</option>
          <option value="user" <%= role === 'user' ? 'selected' : '' %>>普通用户</option>
          <option value="certified" <%= role === 'certified' ? 'selected' : '' %>>认证用户</option>
          <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>管理员</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">筛选</button>
      </div>
    </form>
  </div>
</div>

<!-- 列表 -->
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>昵称</th>
          <th>头像</th>
          <th>手机</th>
          <th>等级</th>
          <th>积分</th>
          <th>状态</th>
          <th>注册时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (list.length === 0) { %>
          <tr><td colspan="9" class="text-center text-muted py-4">暂无用户</td></tr>
        <% } %>
        <% list.forEach(function(u) { %>
          <tr>
            <td><%= u.id %></td>
            <td><%= u.nickname || '-' %></td>
            <td><%= u.avatar ? u.avatar.substring(0,20) + '...' : '-' %></td>
            <td><%= u.phone || '-' %></td>
            <td><span class="badge bg-info"><%= u.level %></span></td>
            <td><%= u.points %></td>
            <td><span class="badge <%= u.status === 1 ? 'bg-success' : 'bg-danger' %>"><%= u.status === 1 ? '正常' : '已禁用' %></span></td>
            <td><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('zh-CN') : '-' %></td>
            <td>
              <form method="POST" action="/admin/users/<%= u.id %>/certify" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-info"><%= u.role === 'certified' ? '取消认证' : '认证' %></button>
              </form>
              <form method="POST" action="/admin/users/<%= u.id %>/ban" style="display:inline">
                <button type="submit" class="btn btn-sm <%= u.status === 1 ? 'btn-outline-danger' : 'btn-outline-success' %>"
                  onclick="return confirm('<%= u.status === 1 ? '确认禁用该用户？' : '确认启用该用户？' %>')">
                  <%= u.status === 1 ? '禁用' : '启用' %>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (var i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&keyword=<%= keyword %>&role=<%= role %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
<%- include('../layouts/footer') %>
