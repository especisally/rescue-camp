<%- include('../layouts/header') %>

<% if (message) { %>
<div class="alert alert-success alert-dismissible fade show"><%= message %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<!-- 修改密码 -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white"><strong>修改密码</strong></div>
  <div class="card-body">
    <form method="POST" action="/admin/settings/change-password" style="max-width:400px">
      <div class="mb-3">
        <label class="form-label">当前密码</label>
        <input type="password" name="currentPassword" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">新密码</label>
        <input type="password" name="newPassword" class="form-control" required minlength="6">
      </div>
      <div class="mb-3">
        <label class="form-label">确认新密码</label>
        <input type="password" name="confirmPassword" class="form-control" required>
      </div>
      <button type="submit" class="btn btn-primary">修改密码</button>
    </form>
  </div>
</div>

<!-- 管理员列表 -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><strong>管理员列表</strong></div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>用户名</th><th>角色</th><th>状态</th><th>创建时间</th></tr>
      </thead>
      <tbody>
        <% admins.forEach(function(a) { %>
          <tr>
            <td><%= a.id %></td>
            <td><%= a.username %></td>
            <td><span class="badge bg-primary"><%= a.role %></span></td>
            <td><span class="badge <%= a.status === 1 ? 'bg-success' : 'bg-danger' %>"><%= a.status === 1 ? '正常' : '禁用' %></span></td>
            <td><%= a.createdAt ? new Date(a.createdAt).toLocaleDateString('zh-CN') : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../layouts/footer') %>
